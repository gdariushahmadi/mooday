{
  "name": "mooday",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest watch",
    "supabase:start": "npx supabase@2.109.1 start -x studio,imgproxy,logflare,vector,supavisor,edge-runtime",
    "supabase:stop": "npx supabase@2.109.1 stop",
    "test:phase2:db": "npx supabase@2.109.1 test db",
    "test:phase2:smoke": "node scripts/phase2-auth-smoke.mjs",
    "test:phase2:e2e": "playwright test",
    "test:phase2": "npm run test:phase2:db && npm run test:phase2:smoke && npm run test:phase2:e2e",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test:ci && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
